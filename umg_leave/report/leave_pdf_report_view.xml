<?xml version = "1.0" encoding = "UTF-8"?>
<odoo>
    <record id = "leave_pdf_report" model = "report.paperformat">
        <field name = "name">A4 - Statement</field>
        <field name = "format">A4</field>
        <field name = "default" eval = "True"/>
        <field name = "page_height">0</field>
        <field name = "page_width">0</field>
        <field name = "orientation">Landscape</field>
        <field name = "margin_top">5</field>
        <field name = "margin_bottom">15</field>
        <field name = "margin_left">7</field>
        <field name = "margin_right">7</field>
        <field name = "header_line" eval = "True"/>
        <field name = "header_spacing">40</field>
        <field name = "dpi">90</field>
    </record>

    <record id = "action_leave_pdf_report" model = "ir.actions.report">
        <field name = "name">PDF Leave Report</field>
        <field name = "model">leave.wizard</field>
        <field name = "report_type">qweb-pdf</field>
        <field name = "report_name">umg_leave.leave_report_template</field>
        <field name = "report_file">umg_leave.leave_report_template</field>
        <field name = "print_report_name">'Leave Report - %s' % (object.date_from or '')</field>
        <!-- <field name = "binding_model_id" ref = "umg_leave.model_leave_wizard"/>
        <field name = "binding_type">report</field> -->
        <field name = "paperformat_id" ref = "leave_pdf_report"/>
    </record>

    <template id="leave_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            table.leave_table {
                                width: 100%;
                                border-collapse: collapse;
                                font-size: 11px;
                            }

                            table.leave_table th {
                                background-color: #4472C4;
                                color: white;
                                font-weight: bold;
                                text-align: center;
                                padding: 6px;
                                border: 1px solid #000000;
                            }

                            table.leave_table td {
                                padding: 5px;
                                border: 1px solid #000000;
                                text-align: center;
                            }

                            table.leave_table tr:nth-child(even) {
                                background-color: #F2F2F2;
                            }

                            .report_title {
                                text-align: center;
                                font-size: 20px;
                                font-weight: bold;
                                margin-bottom: 10px;
                                background-color: #4472C4;
                                color: white;
                                padding: 10px;
                            }

                            .filter_info {
                                font-size: 12px;
                                margin-bottom: 15px;
                            }
                        </style>
                        
                        <table style="width:100%; border:none; margin-bottom:10px;">
                            <tr>
                                <!-- Left: Date Information -->
                                <td style="width:50%; text-align:left; vertical-align:middle;">
                                    <div style="font-size:15px;">
                                        <strong>Date From:</strong>
                                        <span t-esc="wizard.date_from"/>
                                    </div>
                                    <div style="font-size:15px; margin-top:5px;">
                                        <strong>Date To:</strong>
                                        <span t-esc="wizard.date_to"/>
                                    </div>
                                </td>

                                <!-- Right: Company Logo -->
                                <td style="width:50%; text-align:right; vertical-align:middle;">
                                    <img t-if="res_company.logo"
                                        t-att-src="image_data_uri(res_company.logo)"
                                        style="max-height:150px;"/>
                                </td>
                            </tr>
                        </table>

                        <div class="report_title">
                            Leave PDF Report
                        </div>

                        <table class="leave_table">
                            <thead>
                                <tr>
                                    <th>No.</th>
                                    <th>Employee Name</th>
                                    <th>Employee ID</th>
                                    <th>Employee status</th>
                                    <th>BU Name</th>
                                    <th>Department</th>
                                    <th>Leave Title</th>
                                    <th>Entitled Days</th>
                                    <th>Taken Days</th>
                                    <th>Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="i" t-value="0"/>
                                <t t-foreach="wizard.get_leave_report_data()" t-as="line" t-foreach-index="i">
                                    <tr>
                                        <td>
                                            <span t-esc="i + 1"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['employee']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['employee_code']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['employee_status']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['bu_name']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['department']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['leave_type']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['entitled_days']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['taken_days']"/>
                                        </td>
                                        <td>
                                            <span t-esc="line['balance_days']"/>
                                        </td>
                                    </tr>
                                    <t t-set="i" t-value="i+1"/>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>