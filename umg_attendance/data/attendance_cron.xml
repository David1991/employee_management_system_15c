<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="attendance_absent_cron" model="ir.cron">
        <field name="name">Generate Absent Attendance</field>
        <field name="model_id" ref="model_attendance"/>
        <field name="state">code</field>
        <field name="code">model.auto_generate_absent()</field>
        <!-- Run every 1 day -->
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
        <field name="nextcall">2026-07-23 02:30:00</field>
    </record>

</odoo>