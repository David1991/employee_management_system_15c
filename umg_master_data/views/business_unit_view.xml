<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View For Business Unit -->
    <record id="view_tree_business_unit" model="ir.ui.view">
        <field name="name">view.tree.business.unit</field>
        <field name="model">business.unit</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="business_code"/>
                <field name="business_type"/>
            </tree>
        </field>
    </record>

        <!-- Form View For Business Unit -->
    <record id="view_form_business_unit" model="ir.ui.view">
        <field name="name">view.form.business.unit</field>
        <field name="model">business.unit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>    
                    <field name = "photo" widget = "image" class = "oe_avatar"/>
                    <group>
                        <group> 
                            <field name="name"/>
                            <field name="business_code"/>  
                            <field name="business_type"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_business_unit" model="ir.actions.act_window">
        <field name="name">Business Unit</field>
        <field name="res_model">business.unit</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Business Unit Menu -->
    <menuitem
        id="menu_business_unit"
        name="Business Unit"
        parent="menu_master_data_root"
        action="action_business_unit"
        sequence="10"/>

</odoo>